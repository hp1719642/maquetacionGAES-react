# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# BASE DE DATOS MONGODB
# ==========================================
# Si tienes MongoDB instalado localmente:
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_CONTRASEÑA@cluster.mongodb.net/vehiculos_valores

# Si usas MongoDB Atlas (nube):
# MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/vehiculos_valores

# ==========================================
# SEGURIDAD - JWT (JSON Web Tokens)
# ==========================================
# ¡IMPORTANTE! Cambia esta clave por una más segura
JWT_SECRET=GAES_Security_Vehiculos_Valores_2024_Super_Secret_Key_12345
JWT_EXPIRE=8h

# ==========================================
# ENCRIPTACIÓN DE CONTRASEÑAS
# ==========================================
BCRYPT_ROUNDS=10

# ==========================================
# SEGURIDAD - RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# API DE MAPAS (Si usas Google Maps)
# ==========================================
MAPS_API_KEY=tu_api_key_de_google_maps_aqui

# ==========================================
# CORREO ELECTRÓNICO (Para notificaciones)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion